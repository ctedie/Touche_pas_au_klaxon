{
  "name": "touche-pas-au-klaxon/app",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t public",
    "test": "vendor/bin/phpunit",
    "stan": "vendor/bin/phpstan analyse app"
  }
}